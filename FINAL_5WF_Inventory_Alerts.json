      "id": "38c7da1f-0fb8-4f0d-8396-d788fcd13a3b",
      "name": "Fetch Out of Stock from Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4192,
        2672
      ],
      "credentials": {
        "supabaseApi": {
          "id": "f4s3Sbni1QX46Qk1",
          "name": "Supabase account 6"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const biz = $('Prepare Business Data').first().json;\n\n// All items from both nodes\nconst outItems = $('Fetch Out of Stock from Supabase').all().map(i => i.json);\nconst lowItems = $('Fetch Low Stock from Supabase').all().map(i => i.json);\n\nfunction parseItems(items, status) {\n  const seen = new Set();\n  const result = [];\n  items.forEach(p => {\n    if (!p.wc_product_id || seen.has(p.wc_product_id)) return;\n    seen.add(p.wc_product_id);\n    let name = `Product #${p.wc_product_id}`;\n    try {\n      const pd = typeof p.product_data === 'string' ? JSON.parse(p.product_data) : p.product_data;\n      if (pd?.name) name = pd.name;\n    } catch(e) {}\n    result.push({\n      product_id: p.wc_product_id,\n      product_name: name,\n      stock_quantity: p.stock_quantity || 0,\n      status\n    });\n  });\n  return result;\n}\n\nconst outOfStock = parseItems(outItems, 'out_of_stock');\nconst lowStock = parseItems(lowItems, 'low');\nconst allProducts = [...outOfStock, ...lowStock];\n\nif (allProducts.length === 0) {\n  return [{ json: { skip: true, reason: 'No products found', business_id: biz.business_id } }];\n}\n\nreturn [{ json: { ...biz, products: allProducts, lowStockCount: lowStock.length, outOfStockCount: outOfStock.length, totalCount: allProducts.length } }];"
      },
