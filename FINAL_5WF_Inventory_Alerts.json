    {
      "parameters": {
        "jsCode": "const d = $('Process Stock Data').first().json;\nconst raw = $input.first().json;\nconst alreadyNotified = raw.body ? raw.body : (Array.isArray(raw) ? raw : []);\nconst notifiedIds = new Set(alreadyNotified.filter(a => a.telegram_sent).map(a => a.product_id));\nconst newProducts = d.products.filter(p => !notifiedIds.has(p.product_id));\nif (newProducts.length === 0) {\n  return [{ json: { skip: true, reason: 'All already notified today' } }];\n}\nreturn [{ json: { ...d, products: newProducts } }];"
      },
