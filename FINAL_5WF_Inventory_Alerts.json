    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst today = new Date().toISOString().split('T')[0];\n\nlet msg = `⚠️ *Inventory Alert!*\\n`;\nmsg += `🏢 ${d.business_name}\\n`;\nmsg += `📅 ${today}\\n`;\nmsg += `━━━━━━━━━━━━━━━━━━━━━━━━\\n\\n`;\n\nconst outOfStock = d.products.filter(p => p.status === 'out_of_stock');\nconst lowStock = d.products.filter(p => p.status === 'low');\n\nif (outOfStock.length > 0) {\n  msg += `🔴 *Out of Stock (${outOfStock.length})*\\n`;\n  outOfStock.forEach((p, i) => { msg += `${i+1}. ${p.product_name} — 0 units\\n`; });\n  msg += `\\n`;\n}\nif (lowStock.length > 0) {\n  msg += `🟡 *Low Stock (${lowStock.length})*\\n`;\n  lowStock.forEach((p, i) => { msg += `${i+1}. ${p.product_name} — ${p.stock_quantity} units\\n`; });\n  msg += `\\n`;\n}\n\nmsg += `━━━━━━━━━━━━━━━━━━━━━━━━\\n`;\nmsg += `📧 Supplier ko email bhejna hai?\\n`;\nmsg += `Reply karo: *SEND EMAIL* ✅\\n\\n_BizFlow AI_`;\n\nif (msg.length > 4000) msg = msg.substring(0, 4000) + '...';\nreturn [{ json: { ...d, alertMessage: msg } }];"
      },
