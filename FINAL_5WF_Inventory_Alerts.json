    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// Single object ya array dono handle karo\nlet businesses = [];\nif (Array.isArray(raw)) {\n  businesses = raw;\n} else if (raw.body && Array.isArray(raw.body)) {\n  businesses = raw.body;\n} else if (raw.business_id) {\n  businesses = [raw]; // Single object\n}\n\nif (businesses.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nreturn businesses.map(biz => ({ json: biz }));"
      },
