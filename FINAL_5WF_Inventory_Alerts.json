      "parameters": {
        "url": "=https://ibzlykqguiqbwvkbqrau.supabase.co/rest/v1/woocommerce_products?business_id=eq.{{ $('Prepare Business Data').first().json.business_id }}&stock_status=eq.outstock&select=wc_product_id,stock_quantity,stock_status,product_data",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
