    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst isWooOrder = !!(body.id && body.billing && body.line_items);\n\nlet lead = {};\n\nif (isWooOrder) {\n  lead = {\n    source:        'woocommerce_order',\n    wc_order_id:   body.id,\n    name:          ((body.billing.first_name || '') + ' ' + (body.billing.last_name || '')).trim() || 'Unknown',\n    email:         body.billing.email || null,\n    phone:         body.billing.phone || null,\n    city:          body.billing.city || null,\n    country:       body.billing.country || null,\n    order_total:   parseFloat(body.total) || 0,\n    currency:      body.currency || 'PKR',\n    products:      (body.line_items || []).map(i => i.name).join(', '),\n    webhook_secret: $input.first().json.headers?.['x-wc-webhook-secret'] || body.webhook_secret || null,\n    raw_payload:   body\n  };\n} else {\n  lead = {\n    source:      body.source || 'manual',\n    wc_order_id: null,\n    name:        body.name || body.full_name || 'Unknown',\n    email:       body.email || null,\n    phone:       body.phone || null,\n    city:        body.city || null,\n    country:     body.country || 'PK',\n    order_total: parseFloat(body.order_total || body.budget || 0),\n    currency:    body.currency || 'PKR',\n    products:    body.products || body.interested_in || null,\n    webhook_secret: $input.first().json.headers?.['x-wc-webhook-secret'] || body.webhook_secret || null,\n    raw_payload: body\n  };\n}\n\nif (!lead.email && !lead.phone) {\n  throw new Error('Lead must have email or phone');\n}\n\nreturn [{ json: { ...lead, receivedAt: new Date().toISOString() } }];"
      },
