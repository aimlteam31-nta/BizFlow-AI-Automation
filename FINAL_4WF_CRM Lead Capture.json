        "jsCode": "const d = $('Check If Customer').first().json;\nconst raw = $input.first().json;\nconst saved = Array.isArray(raw) ? raw[0] : (Array.isArray(raw.body) ? raw.body[0] : raw);\n\nconst lead_id = saved?.lead_id || null;\n\nreturn [{\n  json: {\n    ...d,\n    lead_id,\n    activity: {\n      business_id:   d.business_id,\n      lead_id:       lead_id,\n      action:        'created',\n      lead_score:    d.lead_score,\n      lead_grade:    d.lead_grade,\n      lead_priority: d.lead_priority,\n      source:        d.source,\n      order_total:   d.order_total,\n      note:          `Lead created via ${d.source}. Score: ${d.lead_score}/100 (${d.lead_grade})`,\n      created_at:    new Date().toISOString()\n    }\n  }\n}];"
