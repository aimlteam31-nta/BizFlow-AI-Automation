    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// AI Lead Scoring — rule based\n// Score: 0-100\nlet score = 50; // base\nconst reasons = [];\n\n// Email present — +10\nif (d.email) { score += 10; reasons.push('Has email'); }\n\n// Phone present — +10\nif (d.phone) { score += 10; reasons.push('Has phone'); }\n\n// High order value\nif (d.order_total >= 5000) { score += 20; reasons.push('High order value'); }\nelse if (d.order_total >= 1000) { score += 10; reasons.push('Medium order value'); }\nelse if (d.order_total > 0) { score += 5; reasons.push('Has order value'); }\n\n// Source bonus\nif (d.source === 'woocommerce_order') { score += 15; reasons.push('WooCommerce order'); }\n\n// Cap at 100\nscore = Math.min(score, 100);\n\n// Grade\nlet grade, priority;\nif (score >= 80)      { grade = 'A'; priority = 'high'; }\nelse if (score >= 60) { grade = 'B'; priority = 'medium'; }\nelse                  { grade = 'C'; priority = 'low'; }\n\nreturn [{\n  json: {\n    ...d,\n    lead_score:    score,\n    lead_grade:    grade,\n    lead_priority: priority,\n    score_reasons: reasons\n  }\n}];"
      },
