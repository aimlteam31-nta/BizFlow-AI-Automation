        "jsCode": "const notif = $('Build Notification').first().json;\nconst raw   = $input.first().json;\nconst biz   = Array.isArray(raw) ? raw[0] : (Array.isArray(raw.body) ? raw.body[0] : raw);\n\n// telegram_chat_id — business table se, ya lead payload se\nconst chatId = biz?.telegram_chat_id \n  || notif?.telegram_chat_id \n  || notif?.raw_payload?.telegram_chat_id \n  || null;\n\nreturn [{ json: { ...notif, telegram_chat_id: chatId ? String(chatId) : null } }];"
