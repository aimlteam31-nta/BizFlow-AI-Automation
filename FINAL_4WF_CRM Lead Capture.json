    {
      "parameters": {
        "jsCode": "const lead = $('Parse Lead Data').first().json;\nconst raw  = $input.first().json;\n\n// Output direct object hai ya array\nlet business_id = null;\n\nif (raw.business_id && raw.is_active) {\n  // Direct object\n  business_id = raw.business_id;\n} else if (Array.isArray(raw) && raw[0]?.business_id) {\n  // Array\n  business_id = raw[0].business_id;\n} else if (Array.isArray(raw.body) && raw.body[0]?.business_id) {\n  // Nested body\n  business_id = raw.body[0].business_id;\n}\n\nif (!business_id) {\n  throw new Error('Business not found for this webhook_secret');\n}\n\nreturn [{ json: { ...lead, business_id } }];"
      },
