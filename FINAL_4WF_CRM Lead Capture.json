    {
      "parameters": {
        "jsCode": "const d = $('Check If Customer').first().json;\nconst raw = $input.first().json;\n\nconst priority = d.lead_priority;\nconst score = d.lead_score;\n\nconst emoji = priority === 'high' ? '🔴' : (priority === 'medium' ? '🟡' : '🟢');\n\nlet msg = `${emoji} *New Lead Captured!*\\n\\n`;\nmsg += `👤 *Name:* ${d.name}\\n`;\nif (d.email)    msg += `📧 *Email:* ${d.email}\\n`;\nif (d.phone)    msg += `📞 *Phone:* ${d.phone}\\n`;\nif (d.city)     msg += `📍 *City:* ${d.city}\\n`;\nif (d.products) msg += `🛍️ *Interested in:* ${d.products}\\n`;\nif (d.order_total > 0) msg += `💰 *Order Value:* ${d.currency} ${d.order_total.toLocaleString()}\\n`;\nmsg += `\\n`;\nmsg += `📊 *Score:* ${score}/100 (Grade ${d.lead_grade})\\n`;\nmsg += `⚡ *Priority:* ${priority.toUpperCase()}\\n`;\nmsg += `📥 *Source:* ${d.source}\\n`;\nmsg += `\\n_BizFlow CRM_`;\n\nreturn [{ json: { ...d, notificationMsg: msg, isNew: true } }];"
      },
