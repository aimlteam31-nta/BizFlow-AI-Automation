      "parameters": {
        "jsCode": "const scored  = $('Score Lead').first().json;\nconst raw     = $input.first().json;\nconst records = Array.isArray(raw) ? raw : (Array.isArray(raw.body) ? raw.body : []);\n\n// Agar customers table mein hai — already customer hai\nconst isExistingCustomer = records.length > 0;\n\nreturn [{ json: { ...scored, isExistingCustomer } }];"
      },
